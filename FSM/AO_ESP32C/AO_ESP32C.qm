         <entry brief="search socket id, send at command">commandParseResult = false;
bool socketFound = GetFreeWsSocketId(&amp;client_link_id);


/* see if there is a free link id (socket id)*/
if(socketFound)
{
    if(ws_cfg_done[client_link_id] == true)
    {
        #if !Q_UTEST

            QEvt *evt = Q_NEW(QEvt, ESP32C_OK_SIG);
            this-&gt;POST(evt,this); 
            TRACE_AO_ESP32C(&quot;Skip Config&quot;);
        #endif
    }
    else
    {
        /* issue the at+cip start command */
        init.esp-&gt;Send_AT_WSCFG( 
                      client_link_id,
                      ws_ping_interval_s,
                      ws_ping_timeout_s );
        m_timeEvt.disarm();
        m_timeEvt.armX( ESP32C_WS_INTERVAL_MS,
                        0);
    }
}else{
   /* dispatch err sig*/
#if !Q_UTEST
   
   QEvt *evt = Q_NEW(QEvt, ESP32C_ERR_SIG);
   this-&gt;POST(evt,this); 

#endif
}
