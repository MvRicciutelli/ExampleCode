     <state name="Base_ConfigState">
      <entry brief="restore connection info buffer, disable urc readiness, empty the defer queue">for(uint8_t i = 0; i&lt;(uint8_t)DRV::ESP32C3::LinkIdMax; i++)
{
    socket_status[i] = ESP32C_SOCKET_STATUS_CLOSE;
}
for(uint8_t i = 0; i&lt;ESP32C3_MAX_WS_SOCKET; i++)
{
    ws_cfg_done[i] = false;
}
hotspot_active = false;
init.esp-&gt;SetUrcReadiness(false);
// empty the defer queue
bool recalled = this-&gt;recall(init.deferQueue);
while(recalled)
{
  recalled = this-&gt;recall(init.deferQueue);
}</entry>
