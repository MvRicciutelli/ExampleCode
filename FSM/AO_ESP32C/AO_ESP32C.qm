       <tran trig="ESP32C_SEND_DATA" target="../../8/4">
        <action brief="trigger data transmission via AT+CIPSEND, reset error counter">
// clean the tx buffer
memset(send_data_buffer, 0, sizeof(send_data_buffer));
// get send data info from the event
memcpy(send_data_buffer, Q_EVT_CAST(SendDataEvt)-&gt;data, Q_EVT_CAST(SendDataEvt)-&gt;length);
send_data_length = Q_EVT_CAST(SendDataEvt)-&gt;length;
client_link_id = Q_EVT_CAST(SendDataEvt)-&gt;socket_id;
// reset error counter
error_counter = 0;
// reset api result buffer
commandParseResult = false;
// start timeout timer
m_timeEvt.disarm();
m_timeEvt.armX( ESP32C_TCP_INTERVAL_MS,
                0);
// prepare for transmission
init.esp-&gt;Send_AT_CIPSEND(client_link_id, send_data_length);

</action>
