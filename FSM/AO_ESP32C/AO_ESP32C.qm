       <state name="Parse_CWJAP_Response">
        <entry brief="parse the content of the command response, when connected self post an ESP32C_OK_SIG, if not ESP32C_ERR_SIG">#if !Q_UTEST
    if(init.esp-&gt;Parse_AT_CWJAP())
    {
       QEvt *evt = Q_NEW(QEvt, ESP32C_OK_SIG);
