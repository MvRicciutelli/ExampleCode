        <state name="Send_AT_WSOPEN">
         <entry>commandParseResult = false;
TRACE_AO_ESP32C(&quot;Prepare Open Ws&quot;);
/* issue the at+cip start command */
if(ws_sub_protocol_len &gt; 0)
{
    if(ws_auth_len&gt;0)
    {
        init.esp-&gt;Send_AT_WSOPEN(client_link_id,
                     ws_uri, ws_sub_protocol, ws_auth );
    }
    else
    {
        init.esp-&gt;Send_AT_WSOPEN(client_link_id,
                             ws_uri, ws_sub_protocol, nullptr );
    }
}else
{
    init.esp-&gt;Send_AT_WSOPEN(client_link_id,
                         ws_uri, nullptr, nullptr );
}

m_timeEvt.disarm();
m_timeEvt.armX( ESP32C_WS_INTERVAL_MS,
                    0);
</entry>
