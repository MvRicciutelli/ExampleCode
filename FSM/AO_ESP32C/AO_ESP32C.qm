  <file name="AO_ESP32C_Signals.h">
   <text>#ifndef __AOESP32CSIGNALS_HP
#define __AOESP32CSIGNALS_HP

#define FOREACH_ESP32C_SIGNALS(MACRO)             \
                         MACRO(      ESP32C_OK_SIG                )\
                         MACRO(      ESP32C_ERR_SIG               )\
                         MACRO(      ESP32C_START_SIG             )\
                         MACRO(      ESP32C_TCP_CONNECT_SIG       )\
                         MACRO(      ESP32C_UDP_CONNECT_SIG       )\
                         MACRO(      ESP32C_CLOSE_SOCKET_SIG      )\
                         MACRO(      ESP32C_READ_DATA_SIG         )\
                         MACRO(      ESP32C_SEND_DATA_SIG         )\
                         MACRO(      ESP32C_OPEN_SERVER_SIG       )\
                         MACRO(      ESP32C_HOTSPOT_CONFIG_SIG    )\
                         MACRO(      ESP32C_DATA_RECEIVE_CHECK_SIG  )\
                         MACRO(      ESP32C_UNSOLICITED_STA_SIG     )\
                         MACRO(      ESP32C_UNSOLICITED_END_SIG     )\
                         MACRO(      ESP32C_UNSOLICITED_TIMEOUT_SIG )\
                         MACRO(      ESP32C_WEBSOCKET_OPEN_SIG      )\
                         MACRO(      ESP32C_WEBSOCKET_CLOSE_SIG     )\
                         MACRO(      ESP32C_WEBSOCKET_SEND_DATA_SIG )\
                         MACRO(      ESP32C_CONNECTION_CHECK_SIG    )\
                         MACRO(      ESP32C_CONNECT_WIFI_SIG        )

#define __ESP32C_SIGNAL_DEF(SIG)      SIG 
#define __ESP32C_SIGNAL_ENUM(SIG)     SIG, 
#define ESP32C_SIGNALS_DEF     FOREACH_ESP32C_SIGNALS(__ESP32C_SIGNAL_DEF)
#define ESP32C_SIGNALS_ENUM    FOREACH_ESP32C_SIGNALS(__ESP32C_SIGNAL_ENUM)
#endif</text>
