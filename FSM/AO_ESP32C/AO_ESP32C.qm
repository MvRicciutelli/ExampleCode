     <tran trig="ESP32C_UNSOLICITED_END">
      <action brief="identify unsolicited message, disarm timer">m_unsolicitedTimeEvt.disarm();
uint32_t token_length = 0;
init.esp-&gt;GetRxBufferData(rx_buffer, sizeof(rx_buffer));
ESP32C3::UnsolicitedMessage type = init.esp-&gt;GetUnsolicitedMessage(rx_buffer, &amp;token_length);
unsolicited_msg_flag = false;
if(type == ESP32C3::IPD)
{
    uint32_t len = 0;
    
    ESP32C3::LinkId socket;
    uint8_t* ipdStart = nullptr;
    uint8_t* data = init.esp-&gt;GetIPD(rx_buffer,&amp;ipdStart, &amp;len,sizeof(rx_buffer), &amp;socket);
    TRACE_AO_ESP32C(&quot;DataRcvd,%d,%d&quot;, (uint8_t)socket, len);
    if(data!= nullptr)
    {
       AO_ESP32C_SocketDataReceiveCallback(this, true , socket, data, len);
    }
}else{
    TRACE_AO_ESP32C(&quot;RecvdUnsol%d&quot;, (uint8_t)type);
}
init.esp-&gt;FlushRx();</action>
      <tran_glyph conn="169,5,0,-1,11,-5">
       <action box="-29,9,29,4"/>
      </tran_glyph>
     </tran>
     <tran trig="ESP32C_UNSOLICITED_STA">
      <action brief="arm or re-arm timeout timer for unsolicited messages">m_unsolicitedTimeEvt.disarm();
unsolicited_msg_flag = true;
m_unsolicitedTimeEvt.armX( ESP32C_UNSOLICITED_TIMEOUT_MS,
                0);</action>
      <tran_glyph conn="177,5,0,-1,16,-8">
       <action box="-29,14,21,4"/>
      </tran_glyph>
     </tran>
     <tran trig="ESP32C_UNSOLICITED_TIMEOUT">
      <action brief="flush esp uart receive">m_unsolicitedTimeEvt.disarm();
unsolicited_msg_flag = false;
uint8_t parse_limit = 10;
uint32_t token_length = 0;
uint32_t offset = 0;
init.esp-&gt;GetRxBufferData(rx_buffer, sizeof(rx_buffer));
ESP32C3::UnsolicitedMessage type = init.esp-&gt;GetUnsolicitedMessage(rx_buffer, &amp;token_length);
while(ESP32C3::UnsolicitedMessage::Unknown != type &amp;&amp; parse_limit!=0)
{
    if(type == ESP32C3::IPD)
    {
        uint32_t len = 0;
        
        ESP32C3::LinkId socket;
        
        uint8_t* ipdStart = nullptr;
        uint8_t* data = init.esp-&gt;GetIPD(rx_buffer,&amp;ipdStart, &amp;len, sizeof(rx_buffer), &amp;socket);
        token_length+= ipdStart-rx_buffer;
        TRACE_AO_ESP32C(&quot;DataRcvd,%d,%d&quot;, (uint8_t)socket, len);
        if(data!= nullptr)
        {
           AO_ESP32C_SocketDataReceiveCallback(this, true , socket, data, len);
        }
    }
    else if(type == ESP32C3::WebSocketData)
    {
        uint32_t len = 0;
        
        ESP32C3::LinkId socket;
        
        uint8_t* wsDataStart = nullptr;
        uint8_t* data = init.esp-&gt;GetWsData(rx_buffer,&amp;wsDataStart, &amp;len, sizeof(rx_buffer), &amp;socket);
        token_length+= wsDataStart-rx_buffer;
        TRACE_AO_ESP32C(&quot;WSDataRcvd,%d,%d&quot;, (uint8_t)socket, len);
        if(data!= nullptr)
        {
           AO_ESP32C_WebSocketDataReceiveCallback(this, true , socket, data, len);
        }
    }
    else if(type == DRV::ESP32C3::SocketConnection )
    {
       
       ESP32C3::LinkId id;
       bool parseResult = init.esp-&gt;GetClientConnectionId(rx_buffer, &amp;id);
       TRACE_AO_ESP32C(&quot;conn%d&quot;, (uint8_t)id);
       if(parseResult){
          
          socket_status[id] = ESP32C_SOCKET_STATUS_SERVER_OPEN;
          AO_ESP32C_ServerTcpSocketOpen(this, true, id);
       }
    }
    else if(type == DRV::ESP32C3::SocketClose )
    {
       
       ESP32C3::LinkId id;
       bool parseResult = init.esp-&gt;GetClientConnectionId(rx_buffer, &amp;id);
       TRACE_AO_ESP32C(&quot;CliDisconn%d&quot;, (uint8_t)id);
       if(parseResult){
          socket_status[id] = ESP32C_SOCKET_STATUS_CLOSE;
       }
    }
    else if(type == DRV::ESP32C3::WifiClientConnection )
    {
       
       AO_ESP32C_HotspotClientConnectionCallback(this, true);
    }
    else if(type == DRV::ESP32C3::WifiClientDisconnection )
    {
       
       /*scan for sockets that used that connection todo this needs to be reworked if we use local lan connectivity*/
       for(int i = 0; i&lt; DRV::ESP32C3::LinkIdMax; i++)
       {
           /* manually close the socket since esp32 does not do that automatically*/
           if(socket_status[i] == ESP32C_SOCKET_STATUS_SERVER_OPEN )
           {
               TcpCloseSocket((DRV::ESP32C3::LinkId)i, this);
           }
       }
       AO_ESP32C_HotspotClientDisconnectionCallback(this, true);
       
    }
    else if(type == DRV::ESP32C3::WifiDisconnection )
    {
       
       TRACE_AO_ESP32C(&quot;WifiAPDisconn&quot;);

       AO_ESP32C_WifiDisconnectionCallback(this, true);
    }
    else if(type == DRV::ESP32C3::WifiConnection )
    {
       
       TRACE_AO_ESP32C(&quot;WifiConn&quot;);
       AO_ESP32C_WifiConnectCallback(this, true);
    }
    else if(type == DRV::ESP32C3::IpAssignment )
    {
       
       TRACE_AO_ESP32C(&quot;IpAss&quot;);
       AO_ESP32C_IpAssignedCallback(this, true);
    }
    else if(type == DRV::ESP32C3::WifiIpClient )
    {
       
       TRACE_AO_ESP32C(&quot;HotspotIpAss&quot;);
       AO_ESP32C_HotspotIpAssignedCallback(this, true);
    }
    else if(type == DRV::ESP32C3::WebsocketConnect)
    {
       ESP32C3::LinkId id;
       
       bool parseResult = init.esp-&gt;GetWsClientConnectionId(rx_buffer, &amp;id);
       TRACE_AO_ESP32C(&quot;WsCliConn%d&quot;, (uint8_t)id);
    }
    else if(type == DRV::ESP32C3::WebsocketDisconnect)
    {
       ESP32C3::LinkId id;
       
       bool parseResult = init.esp-&gt;GetWsClientDisconnectionId(rx_buffer, &amp;id);
       TRACE_AO_ESP32C(&quot;WsCliDisconn%d&quot;, (uint8_t)id);
       if(parseResult)
       {
          socket_status[id] = ESP32C_SOCKET_STATUS_CLOSE;
          AO_ESP32C_WebSocketCloseCallback(this, true,  id);
       }
    }
    else if(type == DRV::ESP32C3::WebsocketClosed)
    {
       ESP32C3::LinkId id;
       
       bool parseResult = init.esp-&gt;GetWsClientClosedId(rx_buffer, &amp;id);
       TRACE_AO_ESP32C(&quot;WsCliClosed%d&quot;, (uint8_t)id);
       if(parseResult)
       {
          socket_status[id] = ESP32C_SOCKET_STATUS_CLOSE;
          AO_ESP32C_WebSocketCloseCallback(this, true,  id);

       }
    }
    else{
        break;
        TRACE_AO_ESP32C(&quot;RecvdUnsol%d&quot;, (uint8_t)type);
    }
    // decresease parse limit counter to forbid infinite loops
    parse_limit--;
    // increase parsing offset
    offset += token_length;
    // advance and parse again
    type = init.esp-&gt;GetUnsolicitedMessage(rx_buffer+offset, &amp;token_length);
}//while loop 
memset(rx_buffer, 0, sizeof(rx_buffer));
// Flush received data
init.esp-&gt;FlushRx();

TRACE_AO_ESP32C(&quot;UnsolicitedEnd&quot;);</action>
