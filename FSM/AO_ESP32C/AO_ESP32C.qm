  <file name="AO_ESP32C.hpp">
   <text>#ifndef AO_ESP32C_H
#define AO_ESP32C_H

#include &quot;ESP32C.hpp&quot;
#include &quot;qpcpp.hpp&quot; // QP/C++ framework API
#include &quot;Signals.hpp&quot;
#include &quot;BSP_QP.hpp&quot;
#include &quot;Debug_Print.hpp&quot;
#include &quot;string.h&quot;

#define PWD_MAX_LEN 64
#define SSID_MAX_LEN 64
#define ESP32C_RESET_INTERVAL_MS 1500
#define ESP32C_WIFI_CONN_INTERVAL_MS 25000
#define ESP32C_TIMEOUT_MS 5000
#define ESP32C_UNSOLICITED_TIMEOUT_MS 25
#define ESP32C_INCOMING_DATA_CHECK_PERIOD_MS 100
#define ESP32C_TCP_INTERVAL_MS 15000
#define ESP32C_RETRY_MAX 2
#define ADDRESS_LEN_MAX 100
#define ESP32C_URI_MAX_LEN 256
#define ESP32C_TX_BUFFER_LEN 2048
#define ESP32C3_WS_HEADER_MAX_LEN 128
#define ESP32C_WS_INTERVAL_MS  (ESP32C_TCP_INTERVAL_MS)
#define ESP32C_TIMEOUT_COUNT_MAX 10
#define ESP32C_AO_MAX_DEFERRED_EVENTS 32
#define ESP32C_AO_CONNECTION_CHECK_PERIOD_MS (10000)

#define ESP32C_SOCKET_STATUS_CLOSE       0 ///&lt; socket close
#define ESP32C_SOCKET_STATUS_OPEN        1 ///&lt; tcp socket open
#define ESP32C_SOCKET_STATUS_WS_OPEN     2 ///&lt; websocket open
#define ESP32C_SOCKET_STATUS_SERVER_OPEN 3 ///&lt; socket opened when esp32c3 acts as server
$declare${AOs::CloseSocketEvt}
$declare${AOs::AO_ESP32C_StartEvent}
$declare${AOs::SendDataEvt}
$declare${AOs::OpenTcpSocketEvt}
$declare${AOs::OpenWsSocketEvt}
$declare${AOs::ConnectApEvt}
namespace AO
{
    typedef struct 
    {
        DRV::ESP32C3* esp;
        //QEQueue requestQueue; /* native QF queue for deferred request events */
        //QEvent const *requestQSto[3]; /* storage for the deferred queue buffer */
        QP::QEQueue* deferQueue;
    }ESP32C_Init_t;
};

// ask QM to declare the AO_ESP32C class ----------------------------------------

$declare${AOs::AO_ESP32C}

// callbacks
void AO_ESP32C_SocketDataReceiveCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id,  uint8_t* data, uint32_t length);
void AO_ESP32C_HotspotOpenCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_HotspotClientConnectionCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_HotspotClientDisconnectionCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_SendDataCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_WifiConnectCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_WifiDisconnectionCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_TcpSocketOpenCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_UdpSocketOpenCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_TcpSocketCloseCallback(AO::AO_ESP32C* caller, bool result,  DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_ReadCompleteCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_ConfigCompleteCallback(AO::AO_ESP32C* caller);
void AO_ESP32C_ServerOpenCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_IpAssignedCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_HotspotIpAssignedCallback(AO::AO_ESP32C* caller, bool result);
void AO_ESP32C_ServerTcpSocketOpen(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_WebSocketOpenCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_WebSocketCloseCallback(AO::AO_ESP32C* caller, bool result,  DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_WebSocketSendCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id);
void AO_ESP32C_WebSocketDataReceiveCallback(AO::AO_ESP32C* caller, bool result, DRV::ESP32C3::LinkId socket_id,  uint8_t* data, uint32_t length);
void AO_ESP32C_TimeoutModuleUnresponsiveCallback(AO::AO_ESP32C* caller);
#endif // BSP_HPP</text>
