   <operation name="AO_ESP32C" type="" visibility="0x00" properties="0x00">
    <documentation>Blinky constructor</documentation>
    <parameter name="_init" type="ESP32C_Init_t&amp;"/>
    <code>  : QActive(Q_STATE_CAST(&amp;AO_ESP32C::initial)),
    m_timeEvt(this, TIMEOUT_SIG, 0U),
    init(_init),
    m_unsolicitedTimeEvt(this, ESP32C_UNSOLICITED_TIMEOUT_SIG, 0U),
    m_incomingDataCheckTimeEvt(this, ESP32C_DATA_RECEIVE_CHECK_SIG, 0U),
    m_connectionCheckTimeEvt(this, ESP32C_CONNECTION_CHECK_SIG, 0U)
</code>
   </operation>
   <operation name="Begin" type="void" visibility="0x00" properties="0x00">
    <parameter name="_mode" type="DRV::ESP32C3::WiFiMode"/>
    <parameter name="caller" type="void*"/>
    <code>AO_ESP32C_StartEvent *evt = Q_NEW(AO_ESP32C_StartEvent, ESP32C_START_SIG);
evt-&gt;mode = _mode;
this-&gt;POST(evt,caller);</code>
   </operation>
   <operation name="ReceiveCompleteCallback" type="void" visibility="0x00" properties="0x00">
    <documentation>/**@brief process hardware event callback data  obtained from uart communication
*@parm event type
*@param caller object
*@param data payload
*/</documentation>
    <parameter name="event" type="DRV::ESP32C3::Event "/>
    <parameter name="caller" type="DRV::ESP32C3* "/>
    <parameter name="data" type="uint8_t* "/>
    <code>// check event type
if(event == DRV::ESP32C3::Event::RespReceived)
{
    // copy data to buffer
    uint32_t len =strnlen((char*)data, sizeof(rx_buffer));
    if(len&gt; sizeof(rx_buffer))
    {
        len = sizeof(rx_buffer);
    }
    memcpy(rx_buffer, data, len);
    rx_buffer[len] = 0;
    QP::QEvt *evt = Q_NEW(QP::QEvt, ESP32C_OK_SIG);
    this-&gt;POST(evt,caller);
    
}else if( event == DRV::ESP32C3::Event::RespErr )
{
    QP::QEvt *evt = Q_NEW(QP::QEvt, ESP32C_ERR_SIG);
    this-&gt;POST(evt,caller);
}
</code>
   </operation>
   <operation name="WiFiConnect" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief initiate connection procedure to a wifi via ssdi and password
*@parm ssid string
*@param password string
*@param caller object
*/</documentation>
    <parameter name="_ssid" type="const uint8_t*"/>
    <parameter name="_pwd" type="const uint8_t*"/>
    <parameter name="caller" type="void*"/>
    <code>// copy wifi credential into the internal buffer
strncpy((char*)ssid,(const char*)_ssid, sizeof(ssid));
strncpy((char*)pwd ,(const char*)_pwd , sizeof(pwd));
// send ESP32_CONNECT_WIFI_SIG
#if !Q_UTEST  // in unit test mode just buffer the input parameters
    QEvt *evt = Q_NEW(QEvt, ESP32C_CONNECT_WIFI_SIG);
    this-&gt;POST(evt,caller);
#else
// do nothing
#endif</code>
   </operation>
   <operation name="WiFiHotspotOpen" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
@brief  sends a requesto to the active object to configure  a esp32c hotspot
@param ssid of the wifi
@param password
@param  connection channel used in the esp32c
@param encryption type adopted by the esp32c
@param maximum number of connections
@param should the ssid hidden
@param reference to caller object
*/</documentation>
    <parameter name="_ssid" type="const uint8_t*"/>
    <parameter name="_pwd" type="const uint8_t*"/>
    <parameter name="_channel_id" type="DRV::ESP32C3::WifiChannelIds"/>
    <parameter name="_encryption" type="DRV::ESP32C3::WifiEncryption"/>
    <parameter name="_max_conn" type="uint8_t"/>
    <parameter name="_hidden" type="bool"/>
    <parameter name="caller" type="void*"/>
    <code>// copy hotspot settings into internal buffers
strncpy((char*)hotspot_ssid,(const char*)_ssid, sizeof(hotspot_ssid));
strncpy((char*)hotspot_pwd ,(const char*)_pwd , sizeof(hotspot_pwd));
hotspot_channel_id = _channel_id;
hotspot_encryption = _encryption;
hotspot_hidden     = _hidden;
hotspot_max_conn   = _max_conn;
#if !Q_UTEST  // in unit test mode just buffer the input parameters
    // send ESP32C_HOTSPOT_CONF_SIG
    QEvt *evt = Q_NEW(QEvt, ESP32C_HOTSPOT_CONFIG_SIG);
    this-&gt;POST(evt,caller);
#endif</code>
   </operation>
   <operation name="TcpOpenSocket" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief  sends a requesto to open a tcp socket to         *       a remote address
*@param  strting address or ip address
*@param  number port
*@param caller object for qp tracing
*/</documentation>
    <parameter name="address" type="const uint8_t*"/>
    <parameter name="port" type="uint16_t"/>
    <parameter name="caller" type="void*"/>
    <code>if( address == nullptr || strnlen((char*)address, sizeof(remote_address))&gt;= sizeof(remote_address))
{
    TRACE_AO_ESP32C(&quot;TcpErrInput&quot;);
    AO_ESP32C_TcpSocketOpenCallback(this, false, client_link_id );
}
else{
    // create event
    OpenTcpSocketEvt *evt = Q_NEW(OpenTcpSocketEvt, ESP32C_TCP_CONNECT_SIG);
    evt-&gt;port = port;
    strncpy((char*)evt-&gt;address,(const char*)address, sizeof(remote_address));
/* Send the ESP32C_TCP_CONNECT_SIG*/
#if !Q_UTEST // in unit test mode just buffer the input parameters
    // send the event
    this-&gt;POST(evt,caller);
#endif
}</code>
   </operation>
   <operation name="SendData" type="bool" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief Trigger transmisison of data via socket *(previously opened)
*@param data pointer
*@param length in bytes
*@param socket id to be used
*@param caller object for qp tracing
*/</documentation>
    <parameter name="data" type="const uint8_t*"/>
    <parameter name="length" type="uint32_t"/>
    <parameter name="_socket_id" type="DRV::ESP32C3::LinkId"/>
    <parameter name="caller" type="void*"/>
    <code>bool retVal = true;
if( length &lt;= sizeof(send_data_buffer)
    &amp;&amp; _socket_id&lt; DRV::ESP32C3::LinkId::LinkIdMax
    &amp;&amp; (socket_status[_socket_id] == ESP32C_SOCKET_STATUS_SERVER_OPEN
        || socket_status[_socket_id] == ESP32C_SOCKET_STATUS_OPEN))
{

#if !Q_UTEST // in unit test mode just buffer the input parameters
/// EVENT CREATION
    SendDataEvt *evt = Q_NEW(SendDataEvt, ESP32C_SEND_DATA_SIG);
    memcpy(evt-&gt;data, data, length);
    evt-&gt;length = length;
    evt-&gt;socket_id = _socket_id;
    this-&gt;POST(evt,caller);
////
#endif
}else //&lt;-- socket not opened OR size exceeded
{
    TRACE_AO_ESP32C(&quot;SNDERR_%d_Sock%d&quot;, length, (uint8_t)socket_status[_socket_id]);
    retVal = false;
#if !Q_UTEST
    AO_ESP32C_SendDataCallback(this, false, _socket_id);
#endif
}
return retVal;</code>
   </operation>
   <operation name="ReadData" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief Receive and read data from an open connection
*@param pointer where data shall be stored
*@param  max data length
*@param timeout in ms
*@param caller object for qp tracing
*/</documentation>
    <parameter name="receive_buffer" type="uint8_t*"/>
    <parameter name="max_length" type="uint32_t"/>
    <parameter name="timeout_ms" type="uint32_t"/>
    <parameter name="caller" type="void*"/>
    <code>receive_data_buffer_ptr = receive_buffer;
receive_data_max_length = max_length;
user_timeout_ms = timeout_ms;
TRACE_AO_ESP32C(&quot;StartRead %d,%d&quot;, max_length, timeout_ms);
#if !Q_UTEST // in unit test mode just buffer the input parameters
    // send ESP32C_HOTSPOT_CONF_SIG
    QEvt *evt = Q_NEW(QEvt, ESP32C_READ_DATA_SIG);
    this-&gt;POST(evt,caller);
#endif</code>
   </operation>
   <operation name="TcpCloseSocket" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief closes a previously opened tcp socket
*@param link id of the socket
*@param caller object for qp tracing
*/</documentation>
    <parameter name="socket_id" type="DRV::ESP32C3::LinkId"/>
    <parameter name="caller" type="void*"/>
    <code>

#if ! Q_UTEST
// create event
    CloseSocketEvt *evt = Q_NEW(CloseSocketEvt, ESP32C_CLOSE_SOCKET_SIG);
    evt-&gt;socket_id = socket_id;
    this-&gt;POST(evt, this);
#endif</code>
   </operation>
   <operation name="OpenServer" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief issue request to open a  server on the desired port
*@param port number
*@param caller object for qp tracing
*@param maximum number of simultaneous supported connections
*/</documentation>
    <parameter name="port" type="uint16_t"/>
    <parameter name="caller" type="void*"/>
    <parameter name="_server_max_connections" type="uint8_t"/>
    <code>// buffer server port
server_port = port;
server_max_connections = _server_max_connections;
#if !Q_UTEST  // in unit test mode just buffer the input parameters
    // send ESP32C_OPEN_SERVER_SIG
    QEvt *evt = Q_NEW(QEvt, ESP32C_OPEN_SERVER_SIG);
    this-&gt;POST(evt,caller);
#endif</code>
   </operation>
   <operation name="GetFreeSocketId" type="uint8_t" visibility="0x02" properties="0x00">
    <documentation>/**
*@brief retrieve the first unoccupied socket id
*@param return value pointer
*@return 1-&gt; found 0-&gt; not found
*/</documentation>
    <parameter name="startOutput_socketId" type="DRV::ESP32C3::LinkId*"/>
    <code>uint8_t retVal = 0;
for( uint8_t id = (uint8_t)(*startOutput_socketId);
     id&lt;(uint8_t)DRV::ESP32C3::LinkIdMax;
     id++)
{
    if(socket_status[id] == ESP32C_SOCKET_STATUS_CLOSE)
    {
        /* unopened socket found */
        retVal = 1;
        *startOutput_socketId = (DRV::ESP32C3::LinkId)id;
        TRACE_AO_ESP32C(&quot;GotId%d&quot;, id);
        break;
    }
}

if(!retVal)
{
    TRACE_AO_ESP32C(&quot;ID_GET_FAI&quot;);
}

return retVal;</code>
   </operation>
   <operation name="GetFreeWsSocketId" type="uint8_t" visibility="0x02" properties="0x00">
    <documentation>/**
*@brief retrieve the first unoccupied websocket socket id
*@param return value pointer
*@return 1-&gt; found 0-&gt; not found
*/</documentation>
    <parameter name="startOutput_socketId" type="DRV::ESP32C3::LinkId*"/>
    <code>uint8_t retVal = 0;
for( uint8_t id = (uint8_t)(*startOutput_socketId);
     id&lt;ESP32C3_MAX_WS_SOCKET;
     id++)
{
    if(socket_status[id] == ESP32C_SOCKET_STATUS_CLOSE)
    {
        /* unopened socket found */
        retVal = 1;
        *startOutput_socketId = (DRV::ESP32C3::LinkId)id;
        TRACE_AO_ESP32C(&quot;GotId%d&quot;, id);
        break;
    }
}

if(!retVal)
{
    TRACE_AO_ESP32C(&quot;ID_GET_FAI&quot;);
}

return retVal;</code>
   </operation>
   <operation name="NotifyUnsolicitedMsgBegin" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief signals the state machine that an unsolicited message is being *received via uart
*@param caller object for qp tracing
*/</documentation>
    <parameter name="caller" type="void*"/>
    <code>#if !Q_UTEST // in unit test mode ignore
    // send ESP32C_UNSOLICITED_STA_SIG
    QEvt *evt = Q_NEW(QEvt, ESP32C_UNSOLICITED_STA_SIG);
    this-&gt;POST(evt,caller);
#endif</code>
   </operation>
   <operation name="NotifyUnsolicitedMsgEnd" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief notify the state machine a complete unsolicited message has been received
*@param caller object for qp tracing
*/</documentation>
    <parameter name="caller" type="void*"/>
    <parameter name="event" type="DRV::ESP32C3::Event"/>
    <parameter name="data" type="uint8_t*"/>
    <code>// copy data to buffer
uint32_t len =strnlen((char*)data, sizeof(rx_buffer));
if(len&gt; sizeof(rx_buffer))
{
    len = sizeof(rx_buffer);
}
memcpy(rx_buffer, data, len);
rx_buffer[len] = 0;
#if !Q_UTEST // in unit test mode ignore
    // send ESP32C_UNSOLICITED_STA_SIG
    QEvt *evt = Q_NEW(QEvt, ESP32C_UNSOLICITED_END_SIG);
    this-&gt;POST(evt,caller);
#endif</code>
   </operation>
   <operation name="WebSocket_Open" type="bool" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief configures a websockets and opens it using a sequence of at commands, it posts the ESP32C_WEBSOCKET_OPEN_SIG
*@param ping interval in seconds
*@param ping timeout in seconds
*@param pointer to websocket header, nullpointer i if no header required
*@param websocket header length in bytes, input 0 if no header is required
*@param uri address 
*@param length of uri
*@param sub protocol  used by the websocket
*@param length of the sub protocol string
*@param auth string
*@param auth string length
*@param caller object
*@return  true process initiates correctly, false wrong parameters event not posted
*/</documentation>
    <parameter name="_ws_ping_interval_s" type="uint32_t"/>
    <parameter name="_ws_ping_timeout_s" type="uint32_t"/>
    <parameter name="_ws_header" type="uint8_t*"/>
    <parameter name="_ws_header_len" type="uint16_t"/>
    <parameter name="_ws_uri" type="uint8_t*"/>
    <parameter name="_ws_uri_len" type="uint16_t"/>
    <parameter name="_ws_sub_protocol" type="const uint8_t*"/>
    <parameter name="_ws_sub_protocol_len" type="uint16_t"/>
    <parameter name="_ws_auth" type="const uint8_t*"/>
    <parameter name="_ws_auth_len" type="uint16_t"/>
    <parameter name="caller" type="void*"/>
    <code>bool retVal = true;
TRACE_AO_ESP32C(&quot;WsOpnReq&quot;);
if(_ws_header_len &lt;= sizeof(ws_header) 
   &amp;&amp; _ws_uri_len &lt;= sizeof(ws_uri)
   &amp;&amp; _ws_uri != nullptr 
   &amp;&amp; _ws_uri_len&gt;0)
{
///
    OpenWsSocketEvt *evt = Q_NEW(OpenWsSocketEvt, ESP32C_WEBSOCKET_OPEN_SIG);
    evt-&gt;ws_uri_len = _ws_uri_len;
    memcpy(evt-&gt;ws_uri, _ws_uri, _ws_uri_len);
    evt-&gt;ws_ping_timeout_s = _ws_ping_timeout_s;
    evt-&gt;ws_ping_interval_s = _ws_ping_interval_s;
    evt-&gt;ws_header_len = _ws_header_len;
    memcpy(evt-&gt;ws_header, _ws_header, _ws_header_len);
    evt-&gt;ws_auth_len = _ws_auth_len;
    memcpy(evt-&gt;ws_auth, _ws_auth, _ws_auth_len);
    evt-&gt;ws_sub_protocol_len = _ws_sub_protocol_len;
    memcpy(evt-&gt;ws_sub_protocol, _ws_sub_protocol, _ws_sub_protocol_len);
///
    /* Send the ESP32C_WEBSOCKET_OPEN signal*/
    #if !Q_UTEST // in unit test mode just buffer the input parameters
        // send ESP32C_WEBSOCKET_OPEN
        this-&gt;POST(evt,caller);
    #endif
///

}else
{
   TRACE_AO_ESP32C(&quot;WSHDRLenErr%d&quot;, _ws_header_len);
   retVal = false;
   AO_ESP32C_WebSocketOpenCallback(this, false, DRV::ESP32C3::LinkIdInvalid);
}
return retVal;</code>
   </operation>
   <operation name="WebSocket_SendData" type="bool" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief Trigger transmisison of data via socket *(previously opened)
*@param data pointer
*@param length in bytes
*@param socket id to be used
*@param websocket opcode
*@param caller object for qp tracing
*/</documentation>
    <parameter name="data" type="const uint8_t*"/>
    <parameter name="length" type="uint32_t"/>
    <parameter name="_socket_id" type="DRV::ESP32C3::LinkId"/>
    <parameter name="_ws_opcode" type="DRV::ESP32C3::WebSockedtOpCode_t"/>
    <parameter name="caller" type="void*"/>
    <code>bool retVal = true;
if( length &lt;= sizeof(send_data_buffer) 
    &amp;&amp; socket_status[_socket_id] == ESP32C_SOCKET_STATUS_WS_OPEN )
{

#if !Q_UTEST // in unit test mode just buffer the input parameters

    SendDataEvt *evt = Q_NEW(SendDataEvt, ESP32C_WEBSOCKET_SEND_DATA_SIG);
    memcpy(evt-&gt;data, data, length);
    evt-&gt;length = length;
    evt-&gt;socket_id = _socket_id;
    evt-&gt;opcode = _ws_opcode;
    this-&gt;POST(evt,caller);
   
#endif
}else //&lt;-- socket not opened OR size exceeded
{
    TRACE_AO_ESP32C(&quot;WS_SNDERR_%d_Sock%d&quot;, length, (uint8_t)socket_status[_socket_id]);
    retVal = false;
#if !Q_UTEST
    AO_ESP32C_WebSocketSendCallback(this, false, _socket_id);
#endif
}
return retVal;</code>
   </operation>
   <operation name="WebSocket_SendData" type="bool" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief Trigger transmisison of data via socket *(previously opened)
*@param data pointer
*@param length in bytes
*@param socket id to be used
*@param websocket opcode
*@param caller object for qp tracing
*@param delay ticks for retry
*/</documentation>
    <parameter name="data" type="const uint8_t*"/>
    <parameter name="length" type="uint32_t"/>
    <parameter name="_socket_id" type="DRV::ESP32C3::LinkId"/>
    <parameter name="_ws_opcode" type="DRV::ESP32C3::WebSockedtOpCode_t"/>
    <parameter name="caller" type="void*"/>
    <parameter name="delayTicks" type="uint8_t"/>
    <code>#ifdef QXK_HPP_ //this api only works with QXK

for (int i = 0; i&lt;5;i++)
{
    if(false == idle_flag)
    {
        QP::QXThread::delay(delayTicks);
    }else{
        return WebSocket_SendData(data, length,_socket_id, _ws_opcode, caller);
    }

}

#endif
return false;</code>
   </operation>
   <operation name="WebSocket_Close" type="bool" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief closes a previously opened websocket
*@param link id of the socket to be closed
*@return success or failure
*/</documentation>
    <parameter name="socket_id" type="DRV::ESP32C3::LinkId"/>
    <parameter name="caller" type="void*"/>
    <code>
/* Create and send the ESP32C_WEBSOCKET_CLOSE*/
#if !Q_UTEST // in unit test mode just buffer the input parameters
    CloseSocketEvt *evt = Q_NEW(CloseSocketEvt, ESP32C_WEBSOCKET_CLOSE_SIG);
    evt-&gt;socket_id = socket_id;
    this-&gt;POST(evt,caller);
#endif
return true;</code>
   </operation>
   <operation name="NotifyUnsolicitedMsgCont" type="void" visibility="0x00" properties="0x00">
    <documentation>/**
*@brief callback to signal that  the stream of an unsolicited message is continuing
*@param calle robject
*/</documentation>
    <parameter name="caller" type="void*"/>
    <code>m_unsolicitedTimeEvt.rearm(ESP32C_UNSOLICITED_TIMEOUT_MS);</code>
   </operation>
   <operation name="UdpOpen" type="bool" visibility="0x00" properties="0x00">
    <documentation>/** @brief  open ad udp listening socket*/</documentation>
    <parameter name="_local_port" type="uint8_t"/>
    <parameter name="_remote_port" type="uint8_t"/>
    <parameter name="address" type="const uint8_t*"/>
    <parameter name="caller" type="void*"/>
    <code>udp_local_port = _local_port;
udp_remote_port = _remote_port;

/* buffer address and port internally*/
strncpy((char*)remote_address,(const char*)address, sizeof(remote_address));

/* Send the ESP32C_TCP_CONNECT_SIG*/
#if !Q_UTEST // in unit test mode just buffer the input parameters
    // send ESP32C_HOTSPOT_CONF_SIG
    QEvt *evt = Q_NEW(QEvt, ESP32C_UDP_CONNECT_SIG);
    this-&gt;POST(evt,caller);
#endif</code>
   </operation>
