       <tran trig="ESP32C_WEBSOCKET_OPEN" target="../../8/6/1">
        <action brief="copy event data, check auth, uri, subprotocol sizes, reset error counter">error_counter = 0;
client_link_id = DRV::ESP32C3::LinkId0;

/* buffer header internally*/
ws_header_len =      Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_header_len;
ws_sub_protocol_len = Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_sub_protocol_len;
ws_auth_len =     Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_auth_len;
ws_uri_len =         Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_uri_len;
ws_ping_interval_s = Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_ping_interval_s;
ws_ping_timeout_s =  Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_ping_timeout_s;
// heaqder may or may not be required
if(ws_header_len&gt;0)
{
    memset(ws_header, 0x0, sizeof(ws_header));
    memcpy((char*)ws_header,
           (const char*)Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_header,
           ws_header_len);
}
else
{
    ws_header_len = 0;
}
if( ws_sub_protocol_len &gt;0 &amp;&amp;  ws_sub_protocol_len&lt; sizeof(ws_sub_protocol))
{
    memset(ws_sub_protocol, 0x0, sizeof(ws_sub_protocol));
    memcpy(ws_sub_protocol,
           Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_sub_protocol,
           ws_sub_protocol_len);
}
else
{
    TRACE_AO_ESP32C(&quot;NoSubProt&quot;);
    ws_sub_protocol_len = 0;
}

if( ws_auth_len &gt;0 &amp;&amp;  ws_auth_len&lt; sizeof(ws_auth))
{
    memset(ws_auth, 0x0, sizeof(ws_auth));
    memcpy(ws_auth, Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_auth, ws_auth_len);
}
else
{
    TRACE_AO_ESP32C(&quot;NoAuth&quot;);
    ws_auth_len = 0;
}

memset(ws_uri, 0x0, sizeof(ws_uri));
memcpy((char*)ws_uri,
            (const char*)Q_EVT_CAST(OpenWsSocketEvt)-&gt;ws_uri,
             ws_uri_len);</action>
